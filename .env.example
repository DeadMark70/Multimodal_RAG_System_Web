VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_API_BASE_URL=http://127.0.0.1:8000
# Comma-separated trusted API hosts for bearer-token attachment.
# Example: VITE_TRUSTED_API_HOSTS=api.example.com,api-staging.example.com
VITE_TRUSTED_API_HOSTS=
# Comma-separated trusted markdown hosts (links/images in assistant content).
# Leave empty to allow only local/current-origin/API hosts.
VITE_TRUSTED_MARKDOWN_HOSTS=
VITE_TEST_MODE=false
VITE_MOCK_MODE=false
